%{
open RegexAST
%}

%token LPAREN RPAREN STAR PLUS PIPE EOF EMPTY
%token <char> CHAR
%type <RegexAST.regex> regex
%start regex

%%
regex: expr EOF { $1 }
     | EOF { Empty }

expr: term { $1 }
    | expr PIPE term { Alt($1, $3) }

term: factor { $1 }
    | factor term { Concat($1, $2) }
    | { Empty }

factor: atom { $1 }
      | factor STAR { Star $1 }
      | factor PLUS { Plus $1 }

atom: CHAR { Char $1 }
    | LPAREN expr RPAREN { $2 }
    | LPAREN RPAREN { Empty }